# ============================================
# Frontend
# ============================================
# Base URL for the FastAPI backend.
VITE_API_BASE=http://127.0.0.1:8000

# Frontend build mode.
NODE_ENV=development

# ============================================
# Backend core
# ============================================
# Required: backend will not start without JWT_SECRET.
JWT_SECRET=replace-with-a-long-random-secret

# Optional: allowed CORS origins, comma-separated.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:8000,http://127.0.0.1:8000

# Optional: logging level for backend runtime.
LOG_LEVEL=INFO

# Optional: PBKDF2 iteration count for password hashing.
PASSWORD_HASH_ITERATIONS=600000

# ============================================
# Seed admin accounts
# ============================================
# Required for first run if you want predictable default admin credentials.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_SALT=change-me-salt

# Optional second admin account.
ADMIN_USERNAME_2=
ADMIN_PASSWORD_2=
ADMIN_SALT_2=

# Optional third admin account.
ADMIN_USERNAME_3=
ADMIN_PASSWORD_3=
ADMIN_SALT_3=

# ============================================
# Local storage
# ============================================
# True = store customer/application data locally in SQLite/JSON.
# False = use Feishu table storage.
USE_LOCAL_STORAGE=true

# SQLite path relative to desktop_app/.
LOCAL_DB_PATH=data/customers.db

# Whether to keep original uploaded files on disk.
STORE_ORIGINAL_UPLOAD_FILES=false

# ============================================
# DeepSeek AI extraction
# ============================================
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ============================================
# Baidu OCR
# ============================================
BAIDU_OCR_APP_ID=
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=

# ============================================
# Feishu table storage
# ============================================
# Choose either personal token mode OR app credential mode.
FEISHU_PERSONAL_BASE_TOKEN=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_APP_TOKEN=
FEISHU_TABLE_ID=

# ============================================
# Feishu wiki/product library
# ============================================
WIKI_APP_ID=
WIKI_APP_SECRET=
