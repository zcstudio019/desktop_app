# ============================================
# Frontend
# ============================================
# Development can point to local FastAPI. In production, prefer leaving this blank
# and let Nginx proxy /api on the same origin.
VITE_API_BASE=http://127.0.0.1:8000

# ============================================
# Backend runtime
# ============================================
JWT_SECRET=replace-with-a-long-random-secret
LOG_LEVEL=INFO
PASSWORD_HASH_ITERATIONS=600000
SERVE_STATIC_FILES=false
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ============================================
# Storage mode
# ============================================
# True  = local customer/application storage in SQLite
# False = Feishu table storage
USE_LOCAL_STORAGE=true
LOCAL_DB_PATH=data/customers.db
STORE_ORIGINAL_UPLOAD_FILES=false

# ============================================
# SQLAlchemy database
# ============================================
# If DATABASE_URL is provided, it takes priority.
DATABASE_URL=
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
SQL_ECHO=false

# ============================================
# Seed admin account
# ============================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_SALT=change-me-salt
ADMIN_USERNAME_2=
ADMIN_PASSWORD_2=
ADMIN_SALT_2=
ADMIN_USERNAME_3=
ADMIN_PASSWORD_3=
ADMIN_SALT_3=

# ============================================
# AI / OCR / external services
# ============================================
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
BAIDU_OCR_APP_ID=
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=

# ============================================
# Feishu
# ============================================
FEISHU_PERSONAL_BASE_TOKEN=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_APP_TOKEN=
FEISHU_TABLE_ID=

# ============================================
# Feishu wiki / product library
# ============================================
WIKI_APP_ID=
WIKI_APP_SECRET=
