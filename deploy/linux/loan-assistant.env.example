# -----------------------------
# Core application
# -----------------------------
APP_ENV=production
DB_BACKEND=mysql
USE_LOCAL_STORAGE=false
WEB_CONCURRENCY=2
CELERY_WORKER_CONCURRENCY=4

# -----------------------------
# Database / RDS
# -----------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=loan_assistant
DB_PASSWORD=change_me
DB_NAME=loan_assistant
# DATABASE_URL=mysql+pymysql://loan_assistant:change_me@127.0.0.1:3306/loan_assistant

# -----------------------------
# Security / API
# -----------------------------
JWT_SECRET=change_me
CORS_ORIGINS=https://your-domain.example
DEEPSEEK_API_KEY=change_me

# -----------------------------
# OCR / Feishu / Wiki
# -----------------------------
BAIDU_OCR_APP_ID=
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=
WIKI_SPACE_ID=
WIKI_DOCUMENT_ID=

# -----------------------------
# Queue / Redis / Celery
# -----------------------------
TASK_QUEUE_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=360
CELERY_MAX_RETRIES=3
CELERY_RETRY_BACKOFF=2
CELERY_RETRY_JITTER=true
WORKER_HEALTHCHECK_ENABLED=true
JOB_STALE_TIMEOUT_SECONDS=900
